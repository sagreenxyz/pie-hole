---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---

<Layout
  title="Phone-In Order List | Pie Hole Pizzeria"
  description="Review your phone-in order list and call Pie Hole Pizzeria at (918) 742-1200 to place your order."
>
  <section class="order-page">
    <div class="order-container">

      <div class="order-header">
        <span class="section-label">Pie Hole Pizzeria</span>
        <h1 class="order-title">Your Phone-In Order List</h1>
        <p class="order-intro">
          Review the items below, then call us at <a href="tel:9187421200" class="phone-link">(918) 742-1200</a> to place your order.
          This is a phone-in order list — your selections are saved here to make it easy to read off to our team.
        </p>
        <a href="tel:9187421200" class="btn btn-primary call-btn">
          📞 Call to Place Order: (918) 742-1200
        </a>
      </div>

      <!-- ORDER LIST (rendered by client-side JS) -->
      <div id="order-content">

        <div id="order-empty" class="order-empty" style="display:none;">
          <p class="empty-icon">🍕</p>
          <h2>Your order list is empty</h2>
          <p>Head over to the menu and add items to build your phone-in order.</p>
          <a href={`${base}menu`} class="btn btn-primary">Browse the Menu</a>
        </div>

        <div id="order-items-wrapper" style="display:none;">
          <div class="order-summary-header">
            <h2>Order Summary</h2>
            <button id="clear-order-btn" class="clear-btn" aria-label="Clear entire order list">
              Clear All
            </button>
          </div>

          <ul id="order-items-list" class="order-items-list" aria-label="Phone-in order items">
          </ul>

          <div class="order-totals">
            <div class="totals-row totals-total">
              <span>Estimated Total</span>
              <span id="order-total">$0.00</span>
            </div>
            <p class="totals-note">Prices are estimates. Tax and any extras will be confirmed when you call.</p>
          </div>

          <div class="call-cta-box">
            <p class="call-cta-label">Ready? Call us with this list:</p>
            <a href="tel:9187421200" class="btn btn-primary cta-btn">📞 (918) 742-1200</a>
            <button id="print-order-btn" class="btn btn-outline-dark print-btn">🖨 Print / Save Order</button>
          </div>
        </div>

      </div>

    </div>
  </section>
</Layout>

<script>
  const STORAGE_KEY = 'piehole-order';

  function getOrder(): OrderItem[] {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function saveOrder(items: OrderItem[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
    window.dispatchEvent(new CustomEvent('piehole-order-updated'));
  }

  interface OrderItem {
    id: string;
    category: string;
    name: string;
    size: string | null;
    price: string;
    priceNum: number;
    quantity: number;
    notes: string;
  }

  function renderOrder() {
    const items = getOrder();
    const empty = document.getElementById('order-empty')!;
    const wrapper = document.getElementById('order-items-wrapper')!;
    const list = document.getElementById('order-items-list')!;
    const totalEl = document.getElementById('order-total')!;

    if (items.length === 0) {
      empty.style.display = '';
      wrapper.style.display = 'none';
      return;
    }

    empty.style.display = 'none';
    wrapper.style.display = '';

    list.innerHTML = '';

    let total = 0;

    // Group by category
    const categories = [...new Set(items.map(i => i.category))];
    categories.forEach(cat => {
      const catHeader = document.createElement('li');
      catHeader.className = 'order-category-header';
      catHeader.textContent = cat;
      list.appendChild(catHeader);

      items.filter(i => i.category === cat).forEach(item => {
        total += item.priceNum * item.quantity;

        const li = document.createElement('li');
        li.className = 'order-item';
        li.dataset.id = item.id;

        const sizeLabel = item.size ? ` (${item.size})` : '';

        li.innerHTML = `
          <div class="item-info">
            <span class="item-name">${item.name}${sizeLabel}</span>
            <span class="item-price">${item.price} each</span>
          </div>
          <div class="item-controls">
            <button class="qty-btn qty-dec" aria-label="Decrease quantity" data-id="${item.id}">−</button>
            <span class="qty-value">${item.quantity}</span>
            <button class="qty-btn qty-inc" aria-label="Increase quantity" data-id="${item.id}">+</button>
            <span class="item-subtotal">$${(item.priceNum * item.quantity).toFixed(2)}</span>
            <button class="remove-btn" aria-label="Remove ${item.name} from order" data-id="${item.id}">✕</button>
          </div>
        `;

        list.appendChild(li);
      });
    });

    totalEl.textContent = `$${total.toFixed(2)}`;

    // Wire up controls
    list.querySelectorAll('.qty-dec').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        let order = getOrder();
        const idx = order.findIndex(i => i.id === id);
        if (idx >= 0) {
          order[idx].quantity -= 1;
          if (order[idx].quantity <= 0) {
            order = order.filter(i => i.id !== id);
          }
          saveOrder(order);
          renderOrder();
        }
      });
    });

    list.querySelectorAll('.qty-inc').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        const order = getOrder();
        const idx = order.findIndex(i => i.id === id);
        if (idx >= 0) {
          order[idx].quantity += 1;
          saveOrder(order);
          renderOrder();
        }
      });
    });

    list.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        const order = getOrder().filter(i => i.id !== id);
        saveOrder(order);
        renderOrder();
      });
    });
  }

  document.getElementById('clear-order-btn')?.addEventListener('click', () => {
    if (confirm('Clear your entire phone-in order list?')) {
      saveOrder([]);
      renderOrder();
    }
  });

  document.getElementById('print-order-btn')?.addEventListener('click', () => {
    window.print();
  });

  renderOrder();
</script>

<style>
  .order-page {
    padding: 3rem 2rem 6rem;
    min-height: 60vh;
  }

  .order-container {
    max-width: 780px;
    margin: 0 auto;
  }

  /* ── HEADER ── */
  .order-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .order-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--color-dark);
    margin: 0.4rem 0 1rem;
  }

  .order-intro {
    font-size: 1.05rem;
    color: var(--color-text-light);
    max-width: 55ch;
    margin: 0 auto 1.8rem;
    line-height: 1.7;
  }

  .phone-link {
    color: var(--color-red);
    font-weight: 700;
    text-decoration: underline;
  }

  .call-btn {
    font-size: 1rem;
  }

  /* ── EMPTY STATE ── */
  .order-empty {
    text-align: center;
    padding: 4rem 2rem;
    background: #fff;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .order-empty h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--color-dark);
    margin-bottom: 0.6rem;
  }

  .order-empty p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  /* ── ORDER LIST ── */
  .order-summary-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
    border-bottom: 3px solid var(--color-red);
  }

  .order-summary-header h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--color-dark);
  }

  .clear-btn {
    background: none;
    border: 1px solid var(--color-red);
    color: var(--color-red);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .clear-btn:hover {
    background: var(--color-red);
    color: #fff;
  }

  .order-items-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #fff;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-bottom: 2rem;
  }

  /* ── TOTALS ── */
  .order-totals {
    background: #fff;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
    padding: 1.2rem 1.5rem;
    margin-bottom: 2rem;
  }

  .totals-row {
    display: flex;
    justify-content: space-between;
    font-size: 1rem;
    padding: 0.3rem 0;
  }

  .totals-total {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-dark);
    border-top: 2px solid rgba(0,0,0,0.1);
    padding-top: 0.7rem;
    margin-top: 0.4rem;
  }

  .totals-note {
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-top: 0.6rem;
  }

  /* ── CALL CTA ── */
  .call-cta-box {
    text-align: center;
    background: var(--color-dark);
    color: #fff;
    border-radius: var(--border-radius);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .call-cta-label {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-gold-light);
    font-family: var(--font-display);
  }

  .cta-btn {
    font-size: 1.1rem;
  }

  .btn-outline-dark {
    border: 2px solid rgba(255,255,255,0.4);
    color: #f0e6d3;
    background: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.7rem 1.6rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-outline-dark:hover {
    background-color: rgba(255,255,255,0.1);
    border-color: #fff;
    transform: translateY(-1px);
  }

  /* ── PRINT STYLES ── */
  @media print {
    .call-cta-box,
    .item-controls .qty-btn,
    .item-controls .remove-btn,
    .clear-btn,
    .print-btn {
      display: none !important;
    }

    .order-page {
      padding: 0;
    }

    .call-cta-box .call-cta-label,
    .call-cta-box .cta-btn {
      display: block !important;
    }

    body::before {
      content: "PHONE-IN ORDER LIST — Pie Hole Pizzeria — (918) 742-1200";
      display: block;
      font-size: 1.2rem;
      font-weight: bold;
      text-align: center;
      padding: 1rem;
      border-bottom: 2px solid #000;
      margin-bottom: 1rem;
    }
  }
</style>

<!-- Global styles for dynamically generated order-list items (via innerHTML in <script>).
     Astro scopes <style> blocks by default, which prevents those rules from reaching
     elements created at runtime. Using is:global here ensures the styles apply correctly. -->
<style is:global>
  .order-category-header {
    background: var(--color-dark-brown);
    color: var(--color-gold-light);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.5rem 1.2rem;
  }

  .order-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.2rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .order-item:last-child {
    border-bottom: none;
  }

  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .item-name {
    font-weight: 700;
    color: var(--color-dark);
    font-size: 1rem;
  }

  .item-price {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .item-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .qty-btn {
    background: var(--color-cream);
    border: 1px solid rgba(0,0,0,0.15);
    color: var(--color-dark);
    width: 28px;
    height: 28px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .qty-btn:hover {
    background: var(--color-red);
    color: #fff;
    border-color: var(--color-red);
  }

  .qty-value {
    min-width: 24px;
    text-align: center;
    font-weight: 700;
    font-size: 1rem;
  }

  .item-subtotal {
    min-width: 52px;
    text-align: right;
    font-weight: 700;
    color: var(--color-dark);
    font-size: 1rem;
  }

  .remove-btn {
    background: none;
    border: none;
    color: var(--color-text-light);
    cursor: pointer;
    font-size: 1rem;
    padding: 0.2rem 0.3rem;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    line-height: 1;
  }

  .remove-btn:hover {
    color: var(--color-red);
    background: rgba(192,57,43,0.08);
  }

  @media print {
    .item-controls .qty-btn,
    .item-controls .remove-btn {
      display: none !important;
    }
  }

  @media (max-width: 600px) {
    .order-item {
      flex-direction: column;
      align-items: flex-start;
    }

    .item-controls {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
