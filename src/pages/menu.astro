---
import Layout from '../layouts/Layout.astro';

const photos = {
  menuHero: 'https://images.squarespace-cdn.com/content/v1/57510c9a4d088e539edafc3d/1466570891382-BS45IRN4F18UKADEB7AN/IMG_3428.JPG?format=2500w',
  strip: [
    'https://images.squarespace-cdn.com/content/v1/57510c9a4d088e539edafc3d/1466570224377-4910C6826JCKP4WMHH6O/IMG_7699.JPG?format=2500w',
    'https://images.squarespace-cdn.com/content/v1/57510c9a4d088e539edafc3d/1466570236433-TRQ4LMATDOIEI00QG7B8/IMG_7723.JPG?format=2500w',
    'https://images.squarespace-cdn.com/content/v1/57510c9a4d088e539edafc3d/1466570891625-8ZGGNOOQ0IM8XV0OO82O/IMG_3449.JPG?format=2500w',
    'https://images.squarespace-cdn.com/content/v1/57510c9a4d088e539edafc3d/1464939657007-V5TU7GTVH6MFWWX5AOZS/6.JPG?format=2500w',
  ],
};

const salads = [
  {
    name: 'Greek Salad',
    desc: 'Mixed lettuces, feta cheese crumbles, kalamata olives, sundried tomatoes, drizzled with olive oil',
    price: '$8.50',
    priceNum: 8.50,
  },
  {
    name: 'Pie Hole Salad',
    desc: 'Mixed lettuces, red onion rings, bell pepper strips, sliced olives and pepperoncini',
    price: '$7.50',
    priceNum: 7.50,
  },
  {
    name: 'Spinach Caesar',
    desc: 'Trimmed baby spinach and grated Parmesan cheese, Caesar dressing',
    price: '$7.50',
    priceNum: 7.50,
  },
];

const gourmetPizzas = [
  {
    name: 'Pie Hole Classic',
    desc: 'Red sauce, pepperoni, Italian sausage, red and green bell peppers, roasted garlic, onion, mushroom, sliced olives, and mozzarella cheese',
  },
  {
    name: 'Mangia Carne',
    desc: 'Red sauce, Italian sausage, pepperoni, Canadian bacon, meatballs, gyro meat, and mozzarella cheese',
  },
  {
    name: 'Pepperiño',
    desc: 'Red sauce, extra pepperoni, spicy jalapeño peppers, and mozzarella cheese',
  },
  {
    name: 'White Pizza',
    desc: 'Alfredo sauce, artichoke hearts, mushrooms, smoked Italian ham, Italian sausage, capers, mozzarella cheese',
  },
  {
    name: 'Campisi',
    desc: 'Red sauce, salami, roasted garlic, and mozzarella cheese',
  },
  {
    name: 'Capri',
    desc: 'Light red sauce, mushrooms, artichoke hearts, smoked Italian ham, Italian sausage, capers and mozzarella cheese',
  },
  {
    name: 'Tiki Pizza',
    desc: 'Red sauce, Canadian bacon, pineapple chunks, green bell peppers, roasted red bell peppers and mozzarella cheese',
  },
  {
    name: 'Romano',
    desc: 'Light red sauce, oven-roasted garlic and chunky tomatoes and mozzarella cheese',
  },
  {
    name: 'Greek Pizza',
    desc: 'Red sauce, spinach, mozzarella cheese, gyro meat, feta cheese, diced tomatoes, kalamata olives and red onions',
  },
  {
    name: 'Rosso',
    desc: 'Red sauce and olive oil with mozzarella cheese, spinach, sliced mushrooms and diced tomatoes',
  },
  {
    name: 'Naples Pizza',
    desc: 'Red sauce, mozzarella cheese, pepperoni, sliced mushrooms, red bell peppers, onions',
  },
  {
    name: 'Four Seasons',
    desc: 'Red sauce, mozzarella cheese, sliced mushrooms, smoked Italian ham, artichoke hearts and salami slices',
  },
  {
    name: 'Veggie Pizza',
    desc: 'Red sauce, spinach, sliced black olives, mushrooms, artichoke hearts, mozzarella cheese',
  },
  {
    name: 'Pesto Pie',
    desc: 'Pesto sauce, chicken, diced tomatoes and goat cheese (no mozzarella)',
  },
  {
    name: 'Pollo Blanco',
    desc: 'Alfredo sauce, spinach, chicken, bacon, mushroom, tomato, mozzarella cheese',
  },
];

const vegToppings = [
  'Spinach', 'Sliced black olives', 'Roasted garlic', 'Green bell peppers',
  'Sliced onion', 'Mushrooms', 'Jalapeño peppers', 'Diced tomato',
  'Pineapple', 'Sun-dried tomato', 'Artichoke hearts', 'Roasted red bell peppers',
  'Green olives', 'Kalamata olives',
];

const meatToppings = [
  'Pepperoni', 'Italian sausage', 'Canadian bacon', 'Salami',
  'Gyro meat', 'Smoked Italian ham', 'Meatballs',
];

const cheeses = ['Mozzarella', 'Feta', 'Goat cheese'];

const drinks = ['Pepsi', 'Diet Pepsi', 'Mtn Dew', 'Mug Root Beer', 'Orange Crush'];
---

<Layout
  title="Menu | Pie Hole Pizzeria"
  description="Browse the full menu at Pie Hole Pizzeria in Tulsa, OK — salads, gourmet pizzas, calzones, and more."
>

  <div class="menu-layout">
  <div class="menu-col">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <img src={photos.menuHero} alt="Fresh pizza at Pie Hole Pizzeria" class="page-hero-bg" />
    <div class="page-hero-content">
      <span class="section-label light">Pie Hole Pizzeria</span>
      <h1 class="page-title">Our Menu</h1>
      <p class="page-subtitle">Fresh ingredients. Bold flavors. Made with love.</p>
    </div>
  </section>

  <div class="menu-wrapper">

    <!-- ── SALADS ── -->
    <section class="menu-section" id="salads">
      <div class="menu-section-header">
        <div class="menu-section-icon">🥗</div>
        <h2>Salads</h2>
      </div>
      <div class="salad-grid">
        {salads.map((item) => (
          <div class="salad-card">
            <div class="salad-card-top">
              <h3>{item.name}</h3>
              <span class="price-badge">{item.price}</span>
            </div>
            <p>{item.desc}</p>
            <button class="add-to-order-btn" data-add-name={item.name} data-add-note="" data-add-price={item.priceNum}>+ Add to Order</button>
          </div>
        ))}
      </div>
      <div class="dressings-note">
        <strong>Available Dressings:</strong> Ranch · Caesar · Balsamic Vinaigrette
        <span class="extra-note">Extra dressings: <strong>$1.00</strong> &nbsp;|&nbsp; Garlic dipping sauce: <strong>$1.00</strong></span>
      </div>
    </section>

    <!-- ── PRICING ── -->
    <section class="menu-section pricing-section" id="pricing">
      <div class="menu-section-header">
        <div class="menu-section-icon">💰</div>
        <h2>Pricing</h2>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card classic-combined-card">
          <h3>Classic Pizza</h3>
          <div class="classic-sizes-wrapper">
            <div class="classic-size-col">
              <div class="classic-col-header">
                <span class="pizza-size-badge">12"</span>
              </div>
              <ul class="pricing-list">
                <li>
                  <span>One topping</span>
                  <span class="price">$16.00</span>
                </li>
                <li>
                  <span>Extra toppings</span>
                  <span class="price">$2.00 each</span>
                </li>
              </ul>
            </div>
            <div class="classic-col-divider"></div>
            <div class="classic-size-col">
              <div class="classic-col-header">
                <span class="pizza-size-badge large-badge">16"</span>
              </div>
              <ul class="pricing-list">
                <li>
                  <span>One topping</span>
                  <span class="price">$18.00</span>
                </li>
                <li>
                  <span>Extra toppings</span>
                  <span class="price">$2.50 each</span>
                </li>
              </ul>
            </div>
          </div>
          <a href="#toppings" class="toppings-link">See available toppings ↓</a>
          <div class="pricing-add-btns">
            <button class="add-to-order-btn add-to-order-btn--sm" data-add-name="Classic Pizza" data-add-note='12"' data-add-price="16" data-classic="true" data-extra-topping-price="2">+ Add 12"</button>
            <button class="add-to-order-btn add-to-order-btn--sm" data-add-name="Classic Pizza" data-add-note='16"' data-add-price="18" data-classic="true" data-extra-topping-price="2.5">+ Add 16"</button>
          </div>
        </div>
        <div class="pricing-card featured-price">
          <div class="gourmet-size-badges">
            <span class="pizza-size-badge gourmet-badge">12"</span>
            <span class="pizza-size-badge gourmet-badge">16"</span>
          </div>
          <h3>Gourmet Pizza</h3>
          <ul class="pricing-list">
            <li>
              <span>12" Gourmet pie</span>
              <span class="price">$19.00</span>
            </li>
            <li>
              <span>16" Gourmet pie</span>
              <span class="price">$23.00</span>
            </li>
          </ul>
          <a href="#gourmet" class="toppings-link">See available gourmet options ↓</a>
          <div class="pricing-add-btns">
            <button class="add-to-order-btn add-to-order-btn--sm" data-add-name="Gourmet Pizza" data-add-note='12"' data-add-price="19">+ Add 12"</button>
            <button class="add-to-order-btn add-to-order-btn--sm" data-add-name="Gourmet Pizza" data-add-note='16"' data-add-price="23">+ Add 16"</button>
          </div>
        </div>
        <div class="pricing-card calzone-card">
          <div class="menu-section-icon small-icon">🥙</div>
          <h3>Calzone</h3>
          <p class="calzone-desc">About half a pizza stuffed in a crescent shaped crust and baked, filled with ricotta cheese and your choice of two ingredients</p>
          <div class="calzone-price">$15.00</div>
          <button class="add-to-order-btn" data-add-name="Calzone" data-add-note="" data-add-price="15">+ Add to Order</button>
        </div>
        <div class="pricing-card bread-card">
          <div class="menu-section-icon small-icon">🧄</div>
          <h3>Asiago Cheese Garlic Bread</h3>
          <p class="calzone-desc">A handful of warm and buttery goodness</p>
          <div class="calzone-price">$5.00</div>
          <button class="add-to-order-btn" data-add-name="Asiago Cheese Garlic Bread" data-add-note="" data-add-price="5">+ Add to Order</button>
        </div>
      </div>
    </section>

    <!-- ── GOURMET PIZZAS ── -->
    <section class="menu-section gourmet-section" id="gourmet">
      <div class="menu-section-header">
        <div class="menu-section-icon">🍕</div>
        <h2>Gourmet Pizzas</h2>
        <p class="section-note">Available in 12" ($19) and 16" ($23)</p>
      </div>
      <div class="gourmet-grid">
        {gourmetPizzas.map((pizza) => (
          <div class="gourmet-card">
            <h3>{pizza.name}</h3>
            <p>{pizza.desc}</p>
            <div class="gourmet-add-btns">
              <button class="add-to-order-btn add-to-order-btn--sm" data-add-name={pizza.name} data-add-note='12"' data-add-price="19">+ 12"</button>
              <button class="add-to-order-btn add-to-order-btn--sm" data-add-name={pizza.name} data-add-note='16"' data-add-price="23">+ 16"</button>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── TOPPINGS ── -->
    <section class="menu-section toppings-section" id="toppings">
      <div class="menu-section-header">
        <div class="menu-section-icon">🫙</div>
        <h2>Toppings &amp; Extras</h2>
      </div>
      <div class="toppings-grid">
        <div class="toppings-card">
          <h3>🥦 Vegetable Toppings</h3>
          <ul class="topping-list">
            {vegToppings.map((t) => <li>{t}</li>)}
          </ul>
        </div>
        <div class="toppings-card">
          <h3>🥩 Meat Toppings</h3>
          <ul class="topping-list">
            {meatToppings.map((t) => <li>{t}</li>)}
          </ul>
          <h3 style="margin-top:1.5rem;">🧀 Cheeses</h3>
          <ul class="topping-list">
            {cheeses.map((t) => <li>{t}</li>)}
          </ul>
        </div>
        <div class="toppings-card drinks-card">
          <h3>🥤 Drinks</h3>
          <ul class="topping-list">
            {drinks.map((d) => <li>{d}</li>)}
          </ul>
          <p class="drink-price">$1.50</p>
        </div>
      </div>
    </section>

    <!-- ── PHOTO STRIP ── -->
    <section class="photo-strip">
      {photos.strip.map((src, i) => (
        <div class="strip-item">
          <img src={src} alt={`Pie Hole Pizzeria photo ${i + 1}`} loading="lazy" />
        </div>
      ))}
    </section>

    <!-- ── ORDER CTA ── -->
    <section class="order-cta">
      <div class="order-cta-inner">
        <h2>Ready to Order?</h2>
        <p>Give us a call for delivery or takeout — we can't wait to make your next meal.</p>
        <a href="tel:9187421200" class="btn btn-primary cta-btn">(918) 742-1200</a>
      </div>
    </section>

  </div><!-- /.menu-wrapper -->
  </div><!-- /.menu-col -->

  <!-- ── ORDER SIDEBAR ── -->
  <aside class="order-sidebar" id="orderSidebar">
    <div class="order-pane" id="orderPane">
      <div class="order-pane-header">
        <span class="order-pane-icon" aria-hidden="true">📋</span>
        <h2 class="order-pane-title">Your Order</h2>
        <button class="order-pane-clear-icon" id="clearOrderBtn" aria-label="Clear order" title="Clear order" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
        </button>
      </div>

      <div class="order-empty-state" id="orderEmptyState">
        <div class="order-empty-icon">🍕</div>
        <p class="order-empty-title">Your order is empty</p>
        <p class="order-empty-hint">Add items from the menu to get started</p>
      </div>

      <ul class="order-pane-list" id="orderList" aria-live="polite"></ul>

      <div class="order-pane-subtotal" id="orderSubtotalSection" hidden>
        <div class="order-subtotal-row">
          <span class="order-subtotal-label">Subtotal</span>
          <span class="order-subtotal-amount" id="orderSubtotal">$0.00</span>
        </div>
        <p class="order-tax-note">Taxes &amp; fees added when order is placed</p>
      </div>

      <div class="order-pane-footer" id="orderFooter">
        <a href="tel:9187421200" class="order-call-btn" aria-label="Call (918) 742-1200 to place order">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.25-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
          <span class="order-call-text">
            <span class="order-call-label">Call to Place Order</span>
            <span class="order-call-number">(918) 742-1200</span>
          </span>
        </a>
        <button class="order-clear-btn" id="clearAllBtn" hidden>Clear All</button>
      </div>
    </div>
  </aside>

  </div><!-- /.menu-layout -->

  <!-- ── CLASSIC PIZZA CONFIGURATION MODAL ── -->
  <dialog id="classicPizzaModal" class="classic-modal" aria-labelledby="classicModalTitle" aria-modal="true">
    <div class="classic-modal-inner">
      <div class="classic-modal-header">
        <h2 id="classicModalTitle" class="classic-modal-title">🍕 Build Your Classic Pizza</h2>
        <button type="button" class="classic-modal-close" id="classicModalClose" aria-label="Close">✕</button>
      </div>
      <div class="classic-modal-body" id="classicModalBody">
        <!-- Filled by JavaScript -->
      </div>
      <div class="classic-modal-footer">
        <div class="classic-price-preview">
          <span class="classic-price-label">Pizza Total</span>
          <span class="classic-price-amount" id="classicModalPrice">$16.00</span>
        </div>
        <button type="button" class="classic-modal-add-btn" id="classicModalAdd" disabled>
          Add to Order
        </button>
      </div>
    </div>
  </dialog>

<style>
  /* ── TWO-COLUMN PAGE LAYOUT ── */
  .menu-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    align-items: start;
    min-height: calc(100vh - 92px);
  }

  .menu-col {
    min-width: 0;
  }

  .order-sidebar {
    position: sticky;
    top: 92px;
    height: calc(100vh - 92px);
    background-color: var(--color-dark);
    border-left: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .order-pane {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  /* ── PAGE HERO ── */
  .page-hero {
    position: relative;
    height: 38vh;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10,5,2,0.65) 0%, rgba(10,5,2,0.55) 100%);
    z-index: 1;
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 1rem 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    color: #fff;
    line-height: 1;
    margin: 0.4rem 0;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-gold-light);
    font-family: var(--font-display);
    font-style: italic;
  }

  /* ── MENU WRAPPER ── */
  .menu-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ── SECTION HEADER ── */
  .menu-section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 3px solid var(--color-red);
  }

  .menu-section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    color: var(--color-dark);
    margin: 0;
  }

  .menu-section-header .section-note {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-left: auto;
    font-style: italic;
  }

  .menu-section-icon {
    font-size: 2rem;
  }

  .small-icon {
    font-size: 1.6rem;
  }

  /* ── SALADS ── */
  .salad-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin-bottom: 1.2rem;
  }

  .salad-card {
    background: #fff;
    border-radius: var(--border-radius);
    padding: 1.4rem;
    box-shadow: var(--shadow);
    border-top: 3px solid var(--color-gold);
  }

  .salad-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .salad-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark);
  }

  .salad-card p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.55;
  }

  .price-badge {
    background-color: var(--color-red);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dressings-note {
    background-color: #fff7ec;
    border-left: 4px solid var(--color-gold);
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    padding: 0.9rem 1.2rem;
    font-size: 0.9rem;
    color: var(--color-text);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    align-items: center;
  }

  .extra-note {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  /* ── PRICING ── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .pricing-card {
    background: #fff;
    border-radius: var(--border-radius);
    padding: 1.5rem 1.2rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    border-top: 3px solid #ddd;
    transition: transform 0.2s;
  }

  .pricing-card:hover {
    transform: translateY(-3px);
  }

  .featured-price {
    border-top-color: var(--color-red);
  }

  .calzone-card, .bread-card {
    border-top-color: var(--color-gold);
  }

  .classic-combined-card {
    grid-column: span 2;
    border-top-color: var(--color-dark-brown);
  }

  .classic-sizes-wrapper {
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .classic-size-col {
    flex: 1;
    padding: 0 0.75rem;
  }

  .classic-size-col:first-child {
    padding-left: 0;
  }

  .classic-size-col:last-child {
    padding-right: 0;
  }

  .classic-col-header {
    margin-bottom: 0.6rem;
  }

  .classic-col-divider {
    width: 1px;
    background: #e8d8c4;
    flex-shrink: 0;
    margin: 0.25rem 0;
  }

  .gourmet-size-badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .pizza-size-badge {
    display: inline-block;
    background-color: var(--color-dark-brown);
    color: #f0e6d3;
    font-weight: 700;
    font-size: 0.85rem;
