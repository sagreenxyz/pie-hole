<script>
  const ORDER_KEY = 'phoneInOrder';

  // Topping data (mirrors frontmatter arrays)
  const VEG_TOPPINGS = [
    'Spinach', 'Sliced black olives', 'Roasted garlic', 'Green bell peppers',
    'Sliced onion', 'Mushrooms', 'Jalapeño peppers', 'Diced tomato',
    'Pineapple', 'Sun-dried tomato', 'Artichoke hearts', 'Roasted red bell peppers',
    'Green olives', 'Kalamata olives',
  ];
  const MEAT_TOPPINGS = [
    'Pepperoni', 'Italian sausage', 'Canadian bacon', 'Salami',
    'Gyro meat', 'Smoked Italian ham', 'Meatballs',
  ];
  const CHEESES = ['Mozzarella', 'Feta', 'Goat cheese'];

  interface OrderItem {
    key: string;
    name: string;
    note: string;
    qty: number;
    price: number;
    // Classic pizza specific (optional)
    isClassic?: boolean;
    requiredTopping?: string;
    cheese?: string;
    extraToppings?: string[];
    extraToppingPrice?: number;
    basePrice?: number;
  }

  function getOrder(): OrderItem[] {
    try {
      return JSON.parse(localStorage.getItem(ORDER_KEY) ?? '[]');
    } catch {
      return [];
    }
  }

  function saveOrder(items: OrderItem[]) {
    localStorage.setItem(ORDER_KEY, JSON.stringify(items));
  }

  function addToOrder(name: string, note: string, price: number) {
    const items = getOrder();
    const key = note ? `${name} (${note})` : name;
    const existing = items.find((i) => i.key === key);
    if (existing) {
      existing.qty++;
    } else {
      items.push({ key, name, note, qty: 1, price });
    }
    saveOrder(items);
    renderOrderPane();
  }

  function addClassicPizzaToOrder(
    size: string,
    basePrice: number,
    extraToppingPrice: number,
    requiredTopping: string,
    cheese: string,
    extraToppings: string[]
  ) {
    const items = getOrder();
    const key = `classic-${size}-${Date.now()}`;
    const totalPrice = basePrice + extraToppings.length * extraToppingPrice;
    items.push({
      key,
      name: 'Classic Pizza',
      note: size,
      qty: 1,
      price: totalPrice,
      isClassic: true,
      requiredTopping,
      cheese,
      extraToppings: [...extraToppings],
      extraToppingPrice,
      basePrice,
    });
    saveOrder(items);
    renderOrderPane();
  }

  function changeQty(key: string, delta: number) {
    const items = getOrder();
    const idx = items.findIndex((i) => i.key === key);
    if (idx !== -1) {
      items[idx].qty += delta;
      if (items[idx].qty <= 0) {
        items.splice(idx, 1);
      }
    }
    saveOrder(items);
    renderOrderPane();
  }

  function deleteOrderItem(key: string) {
    const items = getOrder().filter((i) => i.key !== key);
    saveOrder(items);
    renderOrderPane();
  }

  function removeClassicExtraTopping(key: string, topping: string) {
    const items = getOrder();
    const item = items.find((i) => i.key === key);
    if (item && item.extraToppings) {
      item.extraToppings = item.extraToppings.filter((t) => t !== topping);
      item.price = (item.basePrice ?? 0) + item.extraToppings.length * (item.extraToppingPrice ?? 0);
    }
    saveOrder(items);
    renderOrderPane();
  }

  function clearOrder() {
    saveOrder([]);
    renderOrderPane();
  }

  function fmt(amount: number) {
    return `$${amount.toFixed(2)}`;
  }

  // ── Classic Pizza Modal ──────────────────────────────────────────

  let _modalBasePrice = 16;
  let _modalExtraToppingPrice = 2;
  let _modalSize = '12"';

  function makeRadioOption(groupName: string, value: string): HTMLLabelElement {
    const label = document.createElement('label');
    label.className = 'classic-option-label';
    const input = document.createElement('input');
    input.type = 'radio';
    input.name = groupName;
    input.value = value;
    input.className = 'classic-option-input';
    input.addEventListener('change', updateModalState);
    label.appendChild(input);
    label.appendChild(document.createTextNode(value));
    return label;
  }

  function makeCheckboxOption(groupName: string, value: string): HTMLLabelElement {
    const label = document.createElement('label');
    label.className = 'classic-option-label';
    const input = document.createElement('input');
    input.type = 'checkbox';
    input.name = groupName;
    input.value = value;
    input.className = 'classic-option-input';
    input.addEventListener('change', updateModalState);
    label.appendChild(input);
    label.appendChild(document.createTextNode(value));
    return label;
  }

  function makeToppingColumn(label: string, toppings: string[], makeOption: (name: string, value: string) => HTMLLabelElement, groupName: string): HTMLDivElement {
    const col = document.createElement('div');
    const colLabel = document.createElement('div');
    colLabel.className = 'classic-topping-col-label';
    colLabel.textContent = label;
    col.appendChild(colLabel);
    toppings.forEach((t) => col.appendChild(makeOption(groupName, t)));
    return col;
  }

  function buildModalBody() {
    const body = document.getElementById('classicModalBody');
    if (!body) return;
    body.innerHTML = '';

    // Helper: build a legend with a required badge
    function makeRequiredLegend(label: string): HTMLLegendElement {
      const legend = document.createElement('legend');
      legend.className = 'classic-fieldset-legend';
      const badge = document.createElement('span');
      badge.className = 'classic-required-badge';
      badge.textContent = 'Required';
      legend.appendChild(badge);
      legend.appendChild(document.createTextNode('\u00a0' + label));
      return legend;
    }

    // ── Fieldset 1: Required topping ──
    const fs1 = document.createElement('fieldset');
    fs1.className = 'classic-fieldset';
    fs1.appendChild(makeRequiredLegend('Choose One Topping (included in price)'));
    const cols1 = document.createElement('div');
    cols1.className = 'classic-topping-cols';
    cols1.appendChild(makeToppingColumn('🥦 Vegetables', VEG_TOPPINGS, makeRadioOption, 'classic-required-topping'));
    cols1.appendChild(makeToppingColumn('🥩 Meats', MEAT_TOPPINGS, makeRadioOption, 'classic-required-topping'));
    fs1.appendChild(cols1);
    body.appendChild(fs1);

    // ── Fieldset 2: Cheese ──
    const fs2 = document.createElement('fieldset');
    fs2.className = 'classic-fieldset';
    fs2.appendChild(makeRequiredLegend('Choose Your Cheese'));
    const cheeseRow = document.createElement('div');
    cheeseRow.className = 'classic-cheese-row';
    CHEESES.forEach((c) => cheeseRow.appendChild(makeRadioOption('classic-cheese', c)));
    fs2.appendChild(cheeseRow);
    body.appendChild(fs2);

    // ── Fieldset 3: Optional extra toppings ──
    const fs3 = document.createElement('fieldset');
    fs3.className = 'classic-fieldset';
    const legend3 = document.createElement('legend');
    legend3.className = 'classic-fieldset-legend';
    legend3.appendChild(document.createTextNode('Optional Extra Toppings\u00a0'));
    const priceBadge = document.createElement('span');
    priceBadge.className = 'classic-extra-price-badge';
    priceBadge.textContent = `${fmt(_modalExtraToppingPrice)} each`;
    legend3.appendChild(priceBadge);
    fs3.appendChild(legend3);
    const cols3 = document.createElement('div');
    cols3.className = 'classic-topping-cols';
    cols3.appendChild(makeToppingColumn('🥦 Vegetables', VEG_TOPPINGS, makeCheckboxOption, 'classic-extra-topping'));
    cols3.appendChild(makeToppingColumn('🥩 Meats', MEAT_TOPPINGS, makeCheckboxOption, 'classic-extra-topping'));
    fs3.appendChild(cols3);
    body.appendChild(fs3);
  }

  function getModalSelections() {
    const modal = document.getElementById('classicPizzaModal') as HTMLDialogElement | null;
    if (!modal) return null;
    const requiredInput = modal.querySelector<HTMLInputElement>('input[name="classic-required-topping"]:checked');
    const cheeseInput = modal.querySelector<HTMLInputElement>('input[name="classic-cheese"]:checked');
    const extraInputs = Array.from(modal.querySelectorAll<HTMLInputElement>('input[name="classic-extra-topping"]:checked'));
    return {
      requiredTopping: requiredInput?.value ?? '',
      cheese: cheeseInput?.value ?? '',
      extraToppings: extraInputs.map((i) => i.value),
    };
  }

  function updateModalState() {
    const sel = getModalSelections();
    if (!sel) return;
    const addBtn = document.getElementById('classicModalAdd') as HTMLButtonElement | null;
    const priceEl = document.getElementById('classicModalPrice');
    const isValid = sel.requiredTopping !== '' && sel.cheese !== '';
    if (addBtn) addBtn.disabled = !isValid;
    if (priceEl) {
      const total = _modalBasePrice + sel.extraToppings.length * _modalExtraToppingPrice;
      priceEl.textContent = fmt(total);
    }
  }

  function openClassicModal(size: string, basePrice: number, extraToppingPrice: number) {
    _modalSize = size;
    _modalBasePrice = basePrice;
    _modalExtraToppingPrice = extraToppingPrice;

    const modal = document.getElementById('classicPizzaModal') as HTMLDialogElement | null;
    const title = document.getElementById('classicModalTitle');
    const addBtn = document.getElementById('classicModalAdd') as HTMLButtonElement | null;
    const priceEl = document.getElementById('classicModalPrice');

    if (!modal) return;
    if (title) title.textContent = `🍕 Build Your Classic Pizza (${size})`;
    if (addBtn) addBtn.disabled = true;
    if (priceEl) priceEl.textContent = fmt(basePrice);

    buildModalBody();
    modal.showModal();
  }

  // ── Order Pane Rendering ─────────────────────────────────────────

  const TRASH_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`;
  const DEC_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
  const INC_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`;

  function createQtyControls(item: OrderItem): HTMLDivElement {
    const controls = document.createElement('div');
    controls.className = 'order-item-controls';
    const decBtn = document.createElement('button');
    decBtn.className = 'order-qty-btn';
    decBtn.setAttribute('aria-label', `Decrease quantity of ${item.name}`);
    decBtn.innerHTML = DEC_SVG;
    decBtn.addEventListener('click', () => changeQty(item.key, -1));
    const qtyEl = document.createElement('span');
    qtyEl.className = 'order-item-qty';
    qtyEl.textContent = String(item.qty);
    const incBtn = document.createElement('button');
    incBtn.className = 'order-qty-btn';
    incBtn.setAttribute('aria-label', `Increase quantity of ${item.name}`);
    incBtn.innerHTML = INC_SVG;
    incBtn.addEventListener('click', () => changeQty(item.key, 1));
    controls.appendChild(decBtn);
    controls.appendChild(qtyEl);
    controls.appendChild(incBtn);
    return controls;
  }

  function renderClassicPizzaItem(item: OrderItem, list: HTMLUListElement) {
    const li = document.createElement('li');
    li.className = 'order-pane-item order-pane-item--classic';

    // ── Header row ──
    const headerRow = document.createElement('div');
    headerRow.className = 'order-classic-header';

    const nameGroup = document.createElement('div');
    nameGroup.className = 'order-item-info';
    const nameEl = document.createElement('span');
    nameEl.className = 'order-item-name';
    nameEl.textContent = `${item.name} (${item.note})`;
    nameGroup.appendChild(nameEl);
    const basePriceEl = document.createElement('span');
    basePriceEl.className = 'order-item-unit-price';
    basePriceEl.textContent = `${fmt(item.basePrice ?? 0)} base`;
    nameGroup.appendChild(basePriceEl);

    const controls = createQtyControls(item);

    const itemSubtotal = document.createElement('span');
    itemSubtotal.className = 'order-item-subtotal';
    itemSubtotal.textContent = fmt(item.price * item.qty);

    const removeBtn = document.createElement('button');
    removeBtn.className = 'order-item-remove';
    removeBtn.setAttribute('aria-label', `Remove ${item.name} from order`);
    removeBtn.innerHTML = TRASH_SVG;
    removeBtn.addEventListener('click', () => deleteOrderItem(item.key));

    headerRow.appendChild(nameGroup);
    headerRow.appendChild(controls);
    headerRow.appendChild(itemSubtotal);
    headerRow.appendChild(removeBtn);
    li.appendChild(headerRow);

    // ── Toppings detail ──
    const detail = document.createElement('div');
    detail.className = 'order-classic-detail';

    // Required topping
    if (item.requiredTopping) {
      const row = document.createElement('div');
      row.className = 'order-classic-topping-row';
      const toppingName = document.createElement('span');
      toppingName.className = 'order-classic-topping-name';
      toppingName.textContent = `🍕 ${item.requiredTopping}`;
      const includedTag = document.createElement('span');
      includedTag.className = 'order-classic-tag order-classic-tag--included';
      includedTag.textContent = 'included';
      row.appendChild(toppingName);
      row.appendChild(includedTag);
      detail.appendChild(row);
    }

    // Cheese
    if (item.cheese) {
      const row = document.createElement('div');
      row.className = 'order-classic-topping-row';
      const cheeseName = document.createElement('span');
      cheeseName.className = 'order-classic-topping-name';
      cheeseName.textContent = `🧀 ${item.cheese}`;
      const cheeseTag = document.createElement('span');
      cheeseTag.className = 'order-classic-tag order-classic-tag--cheese';
      cheeseTag.textContent = 'cheese';
      row.appendChild(cheeseName);
      row.appendChild(cheeseTag);
      detail.appendChild(row);
    }

    // Extra toppings
    const extras = item.extraToppings ?? [];
    if (extras.length > 0) {
      const divider = document.createElement('div');
      divider.className = 'order-classic-extras-divider';
      divider.textContent = 'Extra toppings';
      detail.appendChild(divider);

      extras.forEach((topping) => {
        const row = document.createElement('div');
        row.className = 'order-classic-topping-row order-classic-topping-row--extra';
        const toppingName = document.createElement('span');
        toppingName.className = 'order-classic-topping-name';
        toppingName.textContent = `+ ${topping}`;
        const toppingPrice = document.createElement('span');
        toppingPrice.className = 'order-classic-extra-amt';
        toppingPrice.textContent = fmt(item.extraToppingPrice ?? 0);
        const removeExtra = document.createElement('button');
        removeExtra.className = 'order-classic-remove-extra';
        removeExtra.setAttribute('aria-label', `Remove extra ${topping}`);
        removeExtra.textContent = '✕';
        removeExtra.addEventListener('click', () => removeClassicExtraTopping(item.key, topping));
        row.appendChild(toppingName);
        row.appendChild(toppingPrice);
        row.appendChild(removeExtra);
        detail.appendChild(row);
      });

      // Extras subtotal
      const extrasTotal = extras.length * (item.extraToppingPrice ?? 0);
      const subtotalRow = document.createElement('div');
      subtotalRow.className = 'order-classic-extras-subtotal';
      const subtotalLabel = document.createElement('span');
      subtotalLabel.textContent = 'Extras subtotal';
      const subtotalAmount = document.createElement('span');
      subtotalAmount.textContent = fmt(extrasTotal);
      subtotalRow.appendChild(subtotalLabel);
      subtotalRow.appendChild(subtotalAmount);
      detail.appendChild(subtotalRow);
    }

    li.appendChild(detail);
    list.appendChild(li);
  }

  function renderOrderPane() {
    const items = getOrder();
    const sidebar = document.getElementById('orderSidebar') as HTMLElement | null;
    const list = document.getElementById('orderList') as HTMLUListElement | null;
    const emptyState = document.getElementById('orderEmptyState') as HTMLElement | null;
    const subtotalSection = document.getElementById('orderSubtotalSection') as HTMLElement | null;
    const subtotalEl = document.getElementById('orderSubtotal') as HTMLElement | null;
    const clearAllBtn = document.getElementById('clearAllBtn') as HTMLElement | null;
    const clearIcon = document.getElementById('clearOrderBtn') as HTMLElement | null;
    if (!sidebar || !list || !emptyState || !subtotalSection || !subtotalEl) return;

    const hasItems = items.length > 0;
    sidebar.classList.toggle('has-items', hasItems);
    emptyState.hidden = hasItems;
    list.hidden = !hasItems;
    subtotalSection.hidden = !hasItems;
    if (clearAllBtn) clearAllBtn.hidden = !hasItems;
    if (clearIcon) clearIcon.hidden = !hasItems;

    if (!hasItems) {
      list.innerHTML = '';
      return;
    }

    const subtotal = items.reduce((s, i) => s + i.price * i.qty, 0);
    subtotalEl.textContent = fmt(subtotal);

    list.innerHTML = '';
    items.forEach((item) => {
      if (item.isClassic) {
        renderClassicPizzaItem(item, list);
        return;
      }

      const li = document.createElement('li');
      li.className = 'order-pane-item';

      const hasPrice = item.price > 0;

      const info = document.createElement('div');
      info.className = 'order-item-info';

      const nameEl = document.createElement('span');
      nameEl.className = 'order-item-name';
      nameEl.textContent = item.name;
      info.appendChild(nameEl);

      if (item.note) {
        const noteEl = document.createElement('span');
        noteEl.className = 'order-item-note';
        noteEl.textContent = item.note;
        info.appendChild(noteEl);
      }

      if (hasPrice) {
        const unitEl = document.createElement('span');
        unitEl.className = 'order-item-unit-price';
        unitEl.textContent = `${fmt(item.price)} each`;
        info.appendChild(unitEl);
      }

      const controls = createQtyControls(item);

      const itemSubtotal = document.createElement('span');
      itemSubtotal.className = 'order-item-subtotal';
      if (hasPrice) {
        itemSubtotal.textContent = fmt(item.price * item.qty);
      }

      const removeBtn = document.createElement('button');
      removeBtn.className = 'order-item-remove';
      removeBtn.setAttribute('aria-label', `Remove ${item.name} from order`);
      removeBtn.innerHTML = TRASH_SVG;
      removeBtn.addEventListener('click', () => deleteOrderItem(item.key));

      li.appendChild(info);
      li.appendChild(controls);
      li.appendChild(itemSubtotal);
      li.appendChild(removeBtn);
      list.appendChild(li);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderOrderPane();

    // Regular add-to-order buttons (non-classic)
    document.querySelectorAll<HTMLButtonElement>('[data-add-name]:not([data-classic])').forEach((btn) => {
      btn.addEventListener('click', () => {
        const name = btn.dataset.addName ?? '';
        const note = btn.dataset.addNote ?? '';
        const price = parseFloat(btn.dataset.addPrice ?? '0');
        addToOrder(name, note, price);
      });
    });

    // Classic pizza buttons → open modal
    document.querySelectorAll<HTMLButtonElement>('[data-classic="true"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const size = btn.dataset.addNote ?? '12"';
        const basePrice = parseFloat(btn.dataset.addPrice ?? '16');
        const extraToppingPrice = parseFloat(btn.dataset.extraToppingPrice ?? '2');
        openClassicModal(size, basePrice, extraToppingPrice);
      });
    });

    // Modal: close button
    document.getElementById('classicModalClose')?.addEventListener('click', () => {
      (document.getElementById('classicPizzaModal') as HTMLDialogElement | null)?.close();
    });

    // Modal: close on backdrop click
    document.getElementById('classicPizzaModal')?.addEventListener('click', (e) => {
      const modal = e.currentTarget as HTMLDialogElement;
      const rect = modal.getBoundingClientRect();
      const me = e as MouseEvent;
      const clickedOutside =
        me.clientX < rect.left ||
        me.clientX > rect.right ||
        me.clientY < rect.top ||
        me.clientY > rect.bottom;
      if (clickedOutside) modal.close();
    });

    // Modal: Add to Order
    document.getElementById('classicModalAdd')?.addEventListener('click', () => {
      const sel = getModalSelections();
      if (!sel || !sel.requiredTopping || !sel.cheese) return;
      addClassicPizzaToOrder(
        _modalSize,
        _modalBasePrice,
        _modalExtraToppingPrice,
        sel.requiredTopping,
        sel.cheese,
        sel.extraToppings
      );
      (document.getElementById('classicPizzaModal') as HTMLDialogElement | null)?.close();
    });

    document.getElementById('clearOrderBtn')?.addEventListener('click', clearOrder);
    document.getElementById('clearAllBtn')?.addEventListener('click', clearOrder);
  });
</script>

